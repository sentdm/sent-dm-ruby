module Sentdm
  module Resources
    class Contacts
      def create: (
        ?phone_number: String,
        ?sandbox: bool,
        ?idempotency_key: String,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> Sentdm::Models::ContactCreateResponse

      def retrieve: (
        String id,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> Sentdm::Models::ContactRetrieveResponse

      def update: (
        String id,
        ?default_channel: String?,
        ?opt_out: bool?,
        ?sandbox: bool,
        ?idempotency_key: String,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> Sentdm::Models::ContactUpdateResponse

      def list: (
        page: Integer,
        page_size: Integer,
        ?channel: String?,
        ?phone: String?,
        ?search: String?,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> Sentdm::Models::ContactListResponse

      def delete: (
        String id,
        ?sandbox: bool,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> nil

      def initialize: (client: Sentdm::Client) -> void
    end
  end
end
