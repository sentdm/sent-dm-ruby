module Sentdm
  module Models
    type profile_create_params =
      {
        allow_contact_sharing: bool,
        allow_template_sharing: bool,
        billing_contact: Sentdm::ProfileCreateParams::BillingContact?,
        billing_model: String?,
        brand: Sentdm::ProfileCreateParams::Brand?,
        description: String?,
        icon: String?,
        inherit_contacts: bool?,
        inherit_tcr_brand: bool?,
        inherit_tcr_campaign: bool?,
        inherit_templates: bool?,
        name: String,
        payment_details: Sentdm::ProfileCreateParams::PaymentDetails?,
        sandbox: bool,
        short_name: String?,
        whatsapp_business_account: Sentdm::ProfileCreateParams::WhatsappBusinessAccount?,
        idempotency_key: String,
        x_profile_id: String
      }
      & Sentdm::Internal::Type::request_parameters

    class ProfileCreateParams < Sentdm::Internal::Type::BaseModel
      extend Sentdm::Internal::Type::RequestParameters::Converter
      include Sentdm::Internal::Type::RequestParameters

      attr_reader allow_contact_sharing: bool?

      def allow_contact_sharing=: (bool) -> bool

      attr_reader allow_template_sharing: bool?

      def allow_template_sharing=: (bool) -> bool

      attr_accessor billing_contact: Sentdm::ProfileCreateParams::BillingContact?

      attr_accessor billing_model: String?

      attr_accessor brand: Sentdm::ProfileCreateParams::Brand?

      attr_accessor description: String?

      attr_accessor icon: String?

      attr_accessor inherit_contacts: bool?

      attr_accessor inherit_tcr_brand: bool?

      attr_accessor inherit_tcr_campaign: bool?

      attr_accessor inherit_templates: bool?

      attr_reader name: String?

      def name=: (String) -> String

      attr_accessor payment_details: Sentdm::ProfileCreateParams::PaymentDetails?

      attr_reader sandbox: bool?

      def sandbox=: (bool) -> bool

      attr_accessor short_name: String?

      attr_accessor whatsapp_business_account: Sentdm::ProfileCreateParams::WhatsappBusinessAccount?

      attr_reader idempotency_key: String?

      def idempotency_key=: (String) -> String

      attr_reader x_profile_id: String?

      def x_profile_id=: (String) -> String

      def initialize: (
        ?allow_contact_sharing: bool,
        ?allow_template_sharing: bool,
        ?billing_contact: Sentdm::ProfileCreateParams::BillingContact?,
        ?billing_model: String?,
        ?brand: Sentdm::ProfileCreateParams::Brand?,
        ?description: String?,
        ?icon: String?,
        ?inherit_contacts: bool?,
        ?inherit_tcr_brand: bool?,
        ?inherit_tcr_campaign: bool?,
        ?inherit_templates: bool?,
        ?name: String,
        ?payment_details: Sentdm::ProfileCreateParams::PaymentDetails?,
        ?sandbox: bool,
        ?short_name: String?,
        ?whatsapp_business_account: Sentdm::ProfileCreateParams::WhatsappBusinessAccount?,
        ?idempotency_key: String,
        ?x_profile_id: String,
        ?request_options: Sentdm::request_opts
      ) -> void

      def to_hash: -> {
        allow_contact_sharing: bool,
        allow_template_sharing: bool,
        billing_contact: Sentdm::ProfileCreateParams::BillingContact?,
        billing_model: String?,
        brand: Sentdm::ProfileCreateParams::Brand?,
        description: String?,
        icon: String?,
        inherit_contacts: bool?,
        inherit_tcr_brand: bool?,
        inherit_tcr_campaign: bool?,
        inherit_templates: bool?,
        name: String,
        payment_details: Sentdm::ProfileCreateParams::PaymentDetails?,
        sandbox: bool,
        short_name: String?,
        whatsapp_business_account: Sentdm::ProfileCreateParams::WhatsappBusinessAccount?,
        idempotency_key: String,
        x_profile_id: String,
        request_options: Sentdm::RequestOptions
      }

      type billing_contact =
        { email: String, name: String, address: String?, phone: String? }

      class BillingContact < Sentdm::Internal::Type::BaseModel
        attr_accessor email: String

        attr_accessor name: String

        attr_accessor address: String?

        attr_accessor phone: String?

        def initialize: (
          email: String,
          name: String,
          ?address: String?,
          ?phone: String?
        ) -> void

        def to_hash: -> {
          email: String,
          name: String,
          address: String?,
          phone: String?
        }
      end

      type brand =
        {
          compliance: Sentdm::ProfileCreateParams::Brand::Compliance,
          contact: Sentdm::ProfileCreateParams::Brand::Contact,
          business: Sentdm::ProfileCreateParams::Brand::Business?
        }

      class Brand < Sentdm::Internal::Type::BaseModel
        attr_accessor compliance: Sentdm::ProfileCreateParams::Brand::Compliance

        attr_accessor contact: Sentdm::ProfileCreateParams::Brand::Contact

        attr_accessor business: Sentdm::ProfileCreateParams::Brand::Business?

        def initialize: (
          compliance: Sentdm::ProfileCreateParams::Brand::Compliance,
          contact: Sentdm::ProfileCreateParams::Brand::Contact,
          ?business: Sentdm::ProfileCreateParams::Brand::Business?
        ) -> void

        def to_hash: -> {
          compliance: Sentdm::ProfileCreateParams::Brand::Compliance,
          contact: Sentdm::ProfileCreateParams::Brand::Contact,
          business: Sentdm::ProfileCreateParams::Brand::Business?
        }

        type compliance =
          {
            brand_relationship: Sentdm::Models::ProfileCreateParams::Brand::Compliance::brand_relationship,
            vertical: Sentdm::Models::ProfileCreateParams::Brand::Compliance::vertical,
            destination_countries: ::Array[Sentdm::ProfileCreateParams::Brand::Compliance::DestinationCountry]?,
            expected_messaging_volume: String?,
            is_tcr_application: bool?,
            notes: String?,
            phone_number_prefix: String?,
            primary_use_case: String?
          }

        class Compliance < Sentdm::Internal::Type::BaseModel
          attr_accessor brand_relationship: Sentdm::Models::ProfileCreateParams::Brand::Compliance::brand_relationship

          attr_accessor vertical: Sentdm::Models::ProfileCreateParams::Brand::Compliance::vertical

          attr_accessor destination_countries: ::Array[Sentdm::ProfileCreateParams::Brand::Compliance::DestinationCountry]?

          attr_accessor expected_messaging_volume: String?

          attr_accessor is_tcr_application: bool?

          attr_accessor notes: String?

          attr_accessor phone_number_prefix: String?

          attr_accessor primary_use_case: String?

          def initialize: (
            brand_relationship: Sentdm::Models::ProfileCreateParams::Brand::Compliance::brand_relationship,
            vertical: Sentdm::Models::ProfileCreateParams::Brand::Compliance::vertical,
            ?destination_countries: ::Array[Sentdm::ProfileCreateParams::Brand::Compliance::DestinationCountry]?,
            ?expected_messaging_volume: String?,
            ?is_tcr_application: bool?,
            ?notes: String?,
            ?phone_number_prefix: String?,
            ?primary_use_case: String?
          ) -> void

          def to_hash: -> {
            brand_relationship: Sentdm::Models::ProfileCreateParams::Brand::Compliance::brand_relationship,
            vertical: Sentdm::Models::ProfileCreateParams::Brand::Compliance::vertical,
            destination_countries: ::Array[Sentdm::ProfileCreateParams::Brand::Compliance::DestinationCountry]?,
            expected_messaging_volume: String?,
            is_tcr_application: bool?,
            notes: String?,
            phone_number_prefix: String?,
            primary_use_case: String?
          }

          type brand_relationship =
            :BASIC_ACCOUNT
            | :MEDIUM_ACCOUNT
            | :LARGE_ACCOUNT
            | :SMALL_ACCOUNT
            | :KEY_ACCOUNT

          module BrandRelationship
            extend Sentdm::Internal::Type::Enum

            BASIC_ACCOUNT: :BASIC_ACCOUNT
            MEDIUM_ACCOUNT: :MEDIUM_ACCOUNT
            LARGE_ACCOUNT: :LARGE_ACCOUNT
            SMALL_ACCOUNT: :SMALL_ACCOUNT
            KEY_ACCOUNT: :KEY_ACCOUNT

            def self?.values: -> ::Array[Sentdm::Models::ProfileCreateParams::Brand::Compliance::brand_relationship]
          end

          type vertical =
            :PROFESSIONAL
            | :REAL_ESTATE
            | :HEALTHCARE
            | :HUMAN_RESOURCES
            | :ENERGY
            | :ENTERTAINMENT
            | :RETAIL
            | :TRANSPORTATION
            | :AGRICULTURE
            | :INSURANCE
            | :POSTAL
            | :EDUCATION
            | :HOSPITALITY
            | :FINANCIAL
            | :POLITICAL
            | :GAMBLING
            | :LEGAL
            | :CONSTRUCTION
            | :NGO
            | :MANUFACTURING
            | :GOVERNMENT
            | :TECHNOLOGY
            | :COMMUNICATION

          module Vertical
            extend Sentdm::Internal::Type::Enum

            PROFESSIONAL: :PROFESSIONAL
            REAL_ESTATE: :REAL_ESTATE
            HEALTHCARE: :HEALTHCARE
            HUMAN_RESOURCES: :HUMAN_RESOURCES
            ENERGY: :ENERGY
            ENTERTAINMENT: :ENTERTAINMENT
            RETAIL: :RETAIL
            TRANSPORTATION: :TRANSPORTATION
            AGRICULTURE: :AGRICULTURE
            INSURANCE: :INSURANCE
            POSTAL: :POSTAL
            EDUCATION: :EDUCATION
            HOSPITALITY: :HOSPITALITY
            FINANCIAL: :FINANCIAL
            POLITICAL: :POLITICAL
            GAMBLING: :GAMBLING
            LEGAL: :LEGAL
            CONSTRUCTION: :CONSTRUCTION
            NGO: :NGO
            MANUFACTURING: :MANUFACTURING
            GOVERNMENT: :GOVERNMENT
            TECHNOLOGY: :TECHNOLOGY
            COMMUNICATION: :COMMUNICATION

            def self?.values: -> ::Array[Sentdm::Models::ProfileCreateParams::Brand::Compliance::vertical]
          end

          type destination_country = { id: String, is_main: bool }

          class DestinationCountry < Sentdm::Internal::Type::BaseModel
            attr_reader id: String?

            def id=: (String) -> String

            attr_reader is_main: bool?

            def is_main=: (bool) -> bool

            def initialize: (?id: String, ?is_main: bool) -> void

            def to_hash: -> { id: String, is_main: bool }
          end
        end

        type contact =
          {
            name: String,
            business_name: String?,
            email: String?,
            phone: String?,
            phone_country_code: String?,
            role: String?
          }

        class Contact < Sentdm::Internal::Type::BaseModel
          attr_accessor name: String

          attr_accessor business_name: String?

          attr_accessor email: String?

          attr_accessor phone: String?

          attr_accessor phone_country_code: String?

          attr_accessor role: String?

          def initialize: (
            name: String,
            ?business_name: String?,
            ?email: String?,
            ?phone: String?,
            ?phone_country_code: String?,
            ?role: String?
          ) -> void

          def to_hash: -> {
            name: String,
            business_name: String?,
            email: String?,
            phone: String?,
            phone_country_code: String?,
            role: String?
          }
        end

        type business =
          {
            city: String?,
            country: String?,
            country_of_registration: String?,
            entity_type: Sentdm::Models::ProfileCreateParams::Brand::Business::entity_type?,
            legal_name: String?,
            postal_code: String?,
            state: String?,
            street: String?,
            tax_id: String?,
            tax_id_type: String?,
            url: String?
          }

        class Business < Sentdm::Internal::Type::BaseModel
          attr_accessor city: String?

          attr_accessor country: String?

          attr_accessor country_of_registration: String?

          attr_accessor entity_type: Sentdm::Models::ProfileCreateParams::Brand::Business::entity_type?

          attr_accessor legal_name: String?

          attr_accessor postal_code: String?

          attr_accessor state: String?

          attr_accessor street: String?

          attr_accessor tax_id: String?

          attr_accessor tax_id_type: String?

          attr_accessor url: String?

          def initialize: (
            ?city: String?,
            ?country: String?,
            ?country_of_registration: String?,
            ?entity_type: Sentdm::Models::ProfileCreateParams::Brand::Business::entity_type?,
            ?legal_name: String?,
            ?postal_code: String?,
            ?state: String?,
            ?street: String?,
            ?tax_id: String?,
            ?tax_id_type: String?,
            ?url: String?
          ) -> void

          def to_hash: -> {
            city: String?,
            country: String?,
            country_of_registration: String?,
            entity_type: Sentdm::Models::ProfileCreateParams::Brand::Business::entity_type?,
            legal_name: String?,
            postal_code: String?,
            state: String?,
            street: String?,
            tax_id: String?,
            tax_id_type: String?,
            url: String?
          }

          type entity_type =
            :PRIVATE_PROFIT
            | :PUBLIC_PROFIT
            | :NON_PROFIT
            | :SOLE_PROPRIETOR
            | :GOVERNMENT

          module EntityType
            extend Sentdm::Internal::Type::Enum

            PRIVATE_PROFIT: :PRIVATE_PROFIT
            PUBLIC_PROFIT: :PUBLIC_PROFIT
            NON_PROFIT: :NON_PROFIT
            SOLE_PROPRIETOR: :SOLE_PROPRIETOR
            GOVERNMENT: :GOVERNMENT

            def self?.values: -> ::Array[Sentdm::Models::ProfileCreateParams::Brand::Business::entity_type]
          end
        end
      end

      type payment_details =
        { card_number: String, cvc: String, expiry: String, zip_code: String }

      class PaymentDetails < Sentdm::Internal::Type::BaseModel
        attr_accessor card_number: String

        attr_accessor cvc: String

        attr_accessor expiry: String

        attr_accessor zip_code: String

        def initialize: (
          card_number: String,
          cvc: String,
          expiry: String,
          zip_code: String
        ) -> void

        def to_hash: -> {
          card_number: String,
          cvc: String,
          expiry: String,
          zip_code: String
        }
      end

      type whatsapp_business_account =
        { access_token: String, waba_id: String, phone_number_id: String? }

      class WhatsappBusinessAccount < Sentdm::Internal::Type::BaseModel
        attr_accessor access_token: String

        attr_accessor waba_id: String

        attr_accessor phone_number_id: String?

        def initialize: (
          access_token: String,
          waba_id: String,
          ?phone_number_id: String?
        ) -> void

        def to_hash: -> {
          access_token: String,
          waba_id: String,
          phone_number_id: String?
        }
      end
    end
  end
end
